# ====================================
# MiniAgent configuration file
# ====================================

# ==================== Application Configuration ====================
APP_NAME=MiniAgent
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# API Configuration
API_HOST=0.0.0.0
API_PORT=10088

# ==================== Database configuration ====================
# Database path (relative to the project root directory)
SQLITE_DB_PATH=./data/db/miniagent.db
DUCK_DB_PATH=./data/db/duckdb.db

# VectorDB data path (relative to the project root directory)
VECTOR_DB_PATH=./data/vector

# ==================== Storage configuration ====================
STORAGE_DIR=./data/storage

# ==================== Log configuration ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Log directory (relative to the project root directory)
LOG_DIR=./data/log

# ==================== Security Configuration ====================
# CORS-allowed sources (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

JWT_SECRET_KEY=Peb7cbK4LcncSWdvl8NnKWLc10Tx7mBF
JWT_ACCESS_TOKEN_EXPIRE_DAYS=90
JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_DAYS = 1
REFRESH_TOKEN_EXPIRE_DAYS = 7

# ==================== BM25 configuration ====================
BM25_INDEX_PATH=./data/bm25_index
# Maximum cache size (number of items)
BM25_MAX_CACHE_SIZE=1000

# ==================== Performance Configuration ====================
# Maximum concurrency
MAX_CONCURRENT_REQUESTS=10

# Maximum number of tokens in a single conversation
MAX_CONVERSATION_TOKENS=4000

# Maximum number of tool calls
MAX_TOOL_CALLS=5